generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                @id @default(uuid())
  name                  String
  email                 String                @unique
  password              String
  role                  String                @default("customer")
  status                String                @default("active")
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  
  vendorProfile         VendorProfile?
  orders                Order[]
  communityPosts        CommunityPost[]
  sustainabilityCerts   SustainabilityCert[]
  plantTracking         PlantTracking[]
}

model VendorProfile {
  id                  String        @id @default(uuid())
  userId              String        @unique
  farmName            String
  farmDescription     String?
  certificationStatus String        @default("pending")
  farmLocation        Json?
  rating              Float         @default(0)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  produces            Produce[]
  rentalSpaces        RentalSpace[]
}

model Produce {
  id                  String        @id @default(uuid())
  vendorId            String
  name                String
  description         String?
  price               Float
  category            String
  certificationStatus String        @default("pending")
  availableQuantity   Float         @default(0)
  isAvailable         Boolean       @default(true)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  
  vendor              VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  orders              Order[]
}

model RentalSpace {
  id          String        @id @default(uuid())
  vendorId    String
  name        String
  location    Json?
  size        Float
  price       Float
  isAvailable Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  vendor      VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

model Order {
  id          String        @id @default(uuid())
  userId      String
  produceId   String
  vendorId    String?
  quantity    Int
  totalPrice  Float
  status      String        @default("pending")
  orderDate   DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  produce     Produce       @relation(fields: [produceId], references: [id], onDelete: Cascade)
}

model CommunityPost {
  id          String        @id @default(uuid())
  userId      String
  title       String
  content     String
  category    String        @default("general")
  likes       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SustainabilityCert {
  id                String        @id @default(uuid())
  vendorId          String
  certifyingAgency  String
  certificateNumber String        @unique
  issueDate         DateTime
  expiryDate        DateTime
  status            String        @default("pending")
  rejectionReason   String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  
  user              User          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

model PlantTracking {
  id                String        @id @default(uuid())
  userId            String
  plantName         String
  plantType         String
  plantingDate      DateTime
  expectedHarvestDate DateTime?
  healthStatus      String        @default("good")
  growthStage       String        @default("seed")
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}